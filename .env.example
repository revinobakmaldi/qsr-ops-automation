# Power BI app registration.
POWERBI_TENANT_ID=00000000-0000-0000-0000-000000000000
POWERBI_CLIENT_ID=00000000-0000-0000-0000-000000000000
POWERBI_CLIENT_SECRET=replace-me

# SharePoint / Microsoft Graph app registration.
SHAREPOINT_TENANT_ID=00000000-0000-0000-0000-000000000000
SHAREPOINT_CLIENT_ID=00000000-0000-0000-0000-000000000000
SHAREPOINT_CLIENT_SECRET=replace-me

# Optional email delivery app registration. Falls back to SHAREPOINT_* if omitted.
# The app needs Microsoft Graph application permission Mail.Send.
EMAIL_TENANT_ID=00000000-0000-0000-0000-000000000000
EMAIL_CLIENT_ID=00000000-0000-0000-0000-000000000000
EMAIL_CLIENT_SECRET=replace-me
EMAIL_SENDER_UPN=sender@company.com

# Optional public/native app registration used by Teams delivery.
# This must be allowed to use delegated auth/device-code flow.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
GRAPH_DELEGATED_CLIENT_ID=00000000-0000-0000-0000-000000000000

# User account that sends Teams DMs. Must match the signed-in delegated token.
TEAMS_SENDER_UPN=sender@company.com
